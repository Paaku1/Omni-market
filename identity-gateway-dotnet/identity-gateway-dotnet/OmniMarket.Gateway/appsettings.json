{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "bidding-route": {
        "ClusterId": "spring-bidding",
        "Match": { "Path": "/api/bids/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "fastapi-ai",
        "Match": { "Path": "/api/ai/{**catch-all}" }
      }
    },
    "Clusters": {
      "spring-bidding": {
        "Destinations": {
          "d1": { "Address": "http://localhost:8080" }
        }
      },
      "fastapi-ai": {
        "Destinations": {
          "d2": { "Address": "http://localhost:8000" }
        }
      }
    }
  }
}